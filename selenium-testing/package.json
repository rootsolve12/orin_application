{
  "name": "orin-e2e-selenium-framework",
  "version": "2.0.0",
  "description": "Enterprise-grade Selenium E2E automation framework for Orin React Application",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "test": "mocha --require rootHooks.js tests/**/*.test.js --timeout 300000 --reporter mochawesome --reporter-options reportDir=reports/html,reportFilename=orin-e2e-report,overwrite=true,inline=true --exit",
    "test:auth": "mocha --require rootHooks.js tests/auth/*.test.js --timeout 300000 --exit",
    "test:navigation": "mocha --require rootHooks.js tests/navigation/*.test.js --timeout 300000 --exit",
    "test:explore": "mocha --require rootHooks.js tests/explore/*.test.js --timeout 300000 --exit",
    "test:ui": "mocha --require rootHooks.js tests/ui/*.test.js --timeout 300000 --exit",
    "test:master": "mocha --require rootHooks.js tests/master/*.test.js --timeout 300000 --reporter mochawesome --reporter-options reportDir=reports/html,reportFilename=orin-e2e-report,overwrite=true,inline=true --exit",
    "test:ci": "mocha --require rootHooks.js tests/**/*.test.js --timeout 300000 --reporter mochawesome --reporter-options reportDir=reports/html,reportFilename=orin-e2e-report,overwrite=true,inline=true --exit",
    "clean": "rimraf reports",
    "report:open": "start reports\\html\\orin-e2e-report.html"
  },
  "keywords": ["selenium", "e2e", "automation", "orin", "mocha", "POM"],
  "author": "Orin Dev Team",
  "license": "MIT",
  "dependencies": {
    "chai": "^4.3.10",
    "exceljs": "^4.4.0",
    "mocha": "^10.4.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "selenium-webdriver": "^4.18.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "rimraf": "^5.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
