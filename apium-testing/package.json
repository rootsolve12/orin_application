{
  "name": "apium-testing",
  "version": "1.0.0",
  "description": "Appium E2E automated tests for the Orin Flutter Android application",
  "main": "wdio.conf.js",
  "scripts": {
    "test": "npx wdio run wdio.conf.js",
    "test:login": "npx wdio run wdio.conf.js --spec tests/01-splash-login.test.js",
    "test:signup": "npx wdio run wdio.conf.js --spec tests/02-signup.test.js",
    "test:onboarding": "npx wdio run wdio.conf.js --spec tests/03-onboarding.test.js",
    "test:feed": "npx wdio run wdio.conf.js --spec tests/04-event-feed.test.js",
    "test:creation": "npx wdio run wdio.conf.js --spec tests/05-event-creation.test.js",
    "test:detail": "npx wdio run wdio.conf.js --spec tests/06-event-detail.test.js",
    "test:nav": "npx wdio run wdio.conf.js --spec tests/07-navigation.test.js",
    "appium": "npx appium",
    "appium:install-driver": "npx appium driver install uiautomator2"
  },
  "keywords": [
    "appium",
    "e2e",
    "testing",
    "flutter",
    "android",
    "orin"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@wdio/cli": "^9.28.0",
    "@wdio/local-runner": "^9.28.0",
    "@wdio/mocha-framework": "^9.28.0",
    "@wdio/spec-reporter": "^9.28.0",
    "appium": "^3.5.0",
    "chai": "^6.2.2",
    "webdriverio": "^9.28.0"
  },
  "devDependencies": {
    "appium-uiautomator2-driver": "^7.6.1"
  }
}
